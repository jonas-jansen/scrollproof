  "steps": [
    {
      "id": "step-1",
      "label": "01",
      "heading": "Euclid's {em:Windmill}",
      "body": "Draw squares on the sides of a right triangle."
    },
    {
      "id": "step-2",
      "label": "02",
      "heading": "Two Triangles",
      "body": "Draw these two triangles. The angle at $A$ in each is the triangle's own angle plus a square's right angle \u2014 and both squares give the same right angle, so the two are equal:",
      "equation": "{obj:arc1} = {obj:arc3} + {obj:arc5} = {obj:arc3} + {obj:arc4} = {obj:arc2}"
    },
    {
      "id": "step-3",
      "label": "03",
      "heading": "A {em:Quarter-Turn}",
      "body": "Take a copy of the first triangle and turn it a quarter-turn about $A$. It falls exactly onto the second. A rotation is rigid \u2014 it changes nothing but position \u2014 so the two triangles are congruent, and enclose the same area:",
      "equation": "{obj:snap1} = {obj:snap2}"
    }
  ],
